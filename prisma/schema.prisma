generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  SUPER_ADMIN
  ADMIN
  USER
}

enum PermissionAction {
  VIEW
  CREATE
  UPDATE
  DELETE
}

enum UpdateMode {
  REPLACE
  MERGE
}

model User {
  id           Int           @id @default(autoincrement())
  email        String        @unique
  password     String
  role         Role          @default(USER)
  refreshToken String?       @db.Text
  isActive     Boolean       @default(true)
  deletedAt    DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  permissions  Permissions[]

  @@index([email])
  @@index([createdAt])
  @@map("users")
}

model Menus {
  id          Int           @id @default(autoincrement())
  title       String
  url         String
  icon        String
  description String?
  menuId      Int?          @unique
  parentId    Int?
  isActive    Boolean       @default(true)
  deletedAt   DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  permissions Permissions[]

  @@index([id])
  @@map("menus")
}

model Permissions {
  id        Int      @id @default(autoincrement())
  userId    Int
  menuId    Int
  canView   Boolean  @default(false)
  canCreate Boolean  @default(false)
  canUpdate Boolean  @default(false)
  canDelete Boolean  @default(false)
  user      User     @relation(fields: [userId], references: [id])
  menu      Menus    @relation(fields: [menuId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, menuId])
  @@map("permissions")
}

// -------------------------------------------------------------
// CMS MODULES - Home Page Sections
// -------------------------------------------------------------

model SeoMeta {
  id                   Int     @id @default(autoincrement())
  seoTitle             String? @db.VarChar(60)
  seoDescription       String? @db.VarChar(160)
  seoKeywords          String?
  seoCanonicalUrl      String?
  seoMetaImage         String?
  seoRobots            String?
  seoSchema            Json?
  openGraphTitle       String?
  openGraphDescription String?
  openGraphImage       String?
  twitterTitle         String?
  twitterDescription   String?
  twitterImage         String?

  // Relations
  hero         HeroSection?
  clientLogos  ClientLogosSection?
  services     ServicesSection?
  features     FeaturesSection?
  stats        StatsSection?
  testimonials TestimonialsSection?
  pricing      PricingSection?
  blog         BlogSection?
  cta          CtaSection?
  contact      ContactSection?
  footer       FooterSection?

  // Contact Page specific
  workingHours WorkingHoursSection?
  inquiryForm  InquiryFormSection?
  faq          FaqSection?
  socialMedia  SocialMediaSection?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("seo_meta")
}

// -------------------------------------------------------------
// 1. Hero Section
// -------------------------------------------------------------
model HeroSection {
  id                       Int      @id @default(autoincrement())
  heroTitle                String
  heroSubtitle             String?
  heroDescription          String   @db.Text
  heroBackgroundImage      String?
  heroPrimaryButtonLabel   String?
  heroPrimaryButtonLink    String?
  heroSecondaryButtonLabel String?
  heroSecondaryButtonLink  String?
  heroTrustedByText        String?
  heroTrustedLogos         String[] // Array of image URLs
  heroVideo                String?
  heroAnimation            String? // JSON file URL or content

  seoMetaId Int?     @unique
  seoMeta   SeoMeta? @relation(fields: [seoMetaId], references: [id])

  pageIdentifier String @default("home") // E.g., "home", "contact"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("hero_sections")
}

// -------------------------------------------------------------
// 2. Client Logos Section
// -------------------------------------------------------------
model ClientLogosSection {
  id                  Int     @id @default(autoincrement())
  clientsSectionTitle String
  clientsDescription  String? @db.Text

  logos ClientLogo[]

  seoMetaId Int?     @unique
  seoMeta   SeoMeta? @relation(fields: [seoMetaId], references: [id])

  pageIdentifier String @default("home") // E.g., "home", "contact"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("client_logos_sections")
}

model ClientLogo {
  id        Int     @id @default(autoincrement())
  logoImage String
  logoLink  String?

  sectionId Int
  section   ClientLogosSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@map("client_logos")
}

// -------------------------------------------------------------
// 3. Services Section
// -------------------------------------------------------------
model ServicesSection {
  id                      Int     @id @default(autoincrement())
  servicesSectionTitle    String
  servicesSectionSubtitle String?

  services ServiceItem[]

  seoMetaId Int?     @unique
  seoMeta   SeoMeta? @relation(fields: [seoMetaId], references: [id])

  pageIdentifier String @default("home") // E.g., "home", "contact"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("services_sections")
}

model ServiceItem {
  id                 Int     @id @default(autoincrement())
  serviceTitle       String
  serviceDescription String  @db.Text
  serviceIcon        String?
  serviceImage       String?
  serviceLink        String?

  sectionId Int
  section   ServicesSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@map("service_items")
}

// -------------------------------------------------------------
// 4. Features / Benefits Section
// -------------------------------------------------------------
model FeaturesSection {
  id                      Int     @id @default(autoincrement())
  featuresSectionTitle    String
  featuresSectionSubtitle String?

  features FeatureItem[]

  seoMetaId Int?     @unique
  seoMeta   SeoMeta? @relation(fields: [seoMetaId], references: [id])

  pageIdentifier String @default("home") // E.g., "home", "contact"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("features_sections")
}

model FeatureItem {
  id                 Int     @id @default(autoincrement())
  featureTitle       String
  featureDescription String  @db.Text
  featureIcon        String?
  featureImage       String?
  featureCtaLabel    String?
  featureCtaLink     String?

  sectionId Int
  section   FeaturesSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@map("feature_items")
}

// -------------------------------------------------------------
// 5. Agency Statistics Section
// -------------------------------------------------------------
model StatsSection {
  id                Int    @id @default(autoincrement())
  statsSectionTitle String

  stats StatItem[]

  seoMetaId Int?     @unique
  seoMeta   SeoMeta? @relation(fields: [seoMetaId], references: [id])

  pageIdentifier String @default("home") // E.g., "home", "contact"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("stats_sections")
}

model StatItem {
  id         Int     @id @default(autoincrement())
  statNumber String
  statLabel  String
  statIcon   String?

  sectionId Int
  section   StatsSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)

