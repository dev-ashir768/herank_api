// -------------------------------------------------------------
// 6. Testimonials Section
// -------------------------------------------------------------
model TestimonialsSection {
  id                       Int    @id @default(autoincrement())
  testimonialsSectionTitle String

  testimonials TestimonialItem[]

  seoMetaId Int?     @unique
  seoMeta   SeoMeta? @relation(fields: [seoMetaId], references: [id])

  pageIdentifier String @default("home") // E.g., "home", "contact"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("testimonials_sections")
}

model TestimonialItem {
  id                  Int     @id @default(autoincrement())
  testimonialName     String
  testimonialCompany  String?
  testimonialPosition String?
  testimonialReview   String  @db.Text
  testimonialRating   Int     @default(5)
  testimonialImage    String?

  sectionId Int
  section   TestimonialsSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@map("testimonial_items")
}

// -------------------------------------------------------------
// 7. Pricing Section
// -------------------------------------------------------------
model PricingSection {
  id                  Int    @id @default(autoincrement())
  pricingSectionTitle String

  plans PricingPlan[]

  seoMetaId Int?     @unique
  seoMeta   SeoMeta? @relation(fields: [seoMetaId], references: [id])

  pageIdentifier String @default("home") // E.g., "home", "contact"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("pricing_sections")
}

model PricingPlan {
  id               Int      @id @default(autoincrement())
  planName         String
  planPrice        String
  planDescription  String?  @db.Text
  planFeatures     String[] // Array of feature strings, or JSON
  planCtaLabel     String?
  planCtaLink      String?
  planPopularBadge Boolean  @default(false)

  sectionId Int
  section   PricingSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@map("pricing_plans")
}

// -------------------------------------------------------------
// 8. Blog Section
// -------------------------------------------------------------
model BlogSection {
  id                     Int     @id @default(autoincrement())
  blogSectionTitle       String
  blogSectionDescription String? @db.Text

  posts BlogPost[]

  seoMetaId Int?     @unique
  seoMeta   SeoMeta? @relation(fields: [seoMetaId], references: [id])

  pageIdentifier String @default("home") // E.g., "home", "contact"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("blog_sections")
}

model BlogPost {
  id              Int       @id @default(autoincrement())
  blogPostTitle   String
  blogPostExcerpt String?   @db.Text
  blogPostImage   String?
  blogPostSlug    String    @unique
  blogPostAuthor  String?
  blogPostDate    DateTime?

  sectionId Int
  section   BlogSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@map("blog_posts")
}

// -------------------------------------------------------------
// 9. Call to Action (CTA) Section
// -------------------------------------------------------------
model CtaSection {
  id                    Int     @id @default(autoincrement())
  ctaSectionTitle       String
  ctaSectionDescription String? @db.Text
  ctaButtonLabel        String?
  ctaButtonLink         String?
  ctaBackgroundImage    String?
