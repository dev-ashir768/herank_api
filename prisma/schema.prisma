  pageIdentifier String @default("home") // E.g., "home", "contact"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("cta_sections")
}

// -------------------------------------------------------------
// 10. Contact Section
// -------------------------------------------------------------
model ContactSection {
  id                        Int     @id @default(autoincrement())
  contactSectionTitle       String
  contactSectionDescription String? @db.Text
  contactEmail              String?
  contactPhone              String?
  contactWhatsapp           String?
  contactAddress            String? @db.Text
  contactCity               String?
  contactCountry            String?
  contactMapEmbedUrl        String?
  contactForm               String? // Form component
  contactFormFields         Json?

  seoMetaId Int?     @unique
  seoMeta   SeoMeta? @relation(fields: [seoMetaId], references: [id])

  pageIdentifier String @default("home") // E.g., "home", "contact"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("contact_sections")
}

// -------------------------------------------------------------
// 11. Footer Section
// -------------------------------------------------------------
model FooterSection {
  id                      Int     @id @default(autoincrement())
  footerLogo              String?
  footerDescription       String? @db.Text
  footerCopyright         String?
  footerPrivacyPolicyLink String?
  footerTermsLink         String?
  footerNewsletterEnabled Boolean @default(false)
  footerNewsletterTitle   String?

  menuLinks   FooterMenuLink[]
  socialLinks FooterSocialLink[]

  seoMetaId Int?     @unique
  seoMeta   SeoMeta? @relation(fields: [seoMetaId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("footer_sections")
}

model FooterMenuLink {
  id    Int    @id @default(autoincrement())
  label String
  url   String

  sectionId Int
  section   FooterSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@map("footer_menu_links")
}

model FooterSocialLink {
  id   Int    @id @default(autoincrement())
  icon String
  url  String

  sectionId Int
  section   FooterSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@map("footer_social_links")
}

